  </property>
  <property name="windowTitle">
   <string>College Tracker</string>
  </property>
  <property name="styleSheet">
   <string notr="true">/* =============================================
   College Tracker — Typora 风格全局样式表
   深色侧边栏 + 浅色内容区 + Dashboard 卡片
   ============================================= */

/* ---------- 全局 ---------- */
QMainWindow {
    background-color: #FFFAF0;
    font-family: &quot;PingFang SC&quot;, &quot;Helvetica Neue&quot;, &quot;Microsoft YaHei&quot;;
}

/* ---------- 米黄色侧边栏 ---------- */
#sidebarFrame {
    background-color: #FDF5E6;
    border: none;
}

/* 用户信息卡片 */
#userProfileWidget {
    background-color: transparent;
    border-bottom: 1px solid #e8ddd0;
    padding: 24px 16px 20px 16px;
    margin-bottom: 8px;
}

#userNameLbl {
    font-size: 17px;
    font-weight: bold;
    color: #2d3748;
    padding: 0px;
}

#detailLbl {
    font-size: 12px;
    color: #718096;
    margin-top: 4px;
}

#majorLbl {
    font-size: 11px;
    color: #8a8a8a;
    margin-top: 2px;
}

/* 侧边栏导航按钮 */
#sidebarFrame QPushButton {
    background-color: transparent;
    color: #5a4a3a;
    border: none;
    border-left: 3px solid transparent;
    border-radius: 0px 8px 8px 0px;
    padding: 10px 16px;
    text-align: left;
    font-size: 13px;
    margin: 2px 10px;
}

#sidebarFrame QPushButton:hover {
    background-color: #efe0cc;
    color: #2d3748;
    border-left: 3px solid #4a90d9;
}

#sidebarFrame QPushButton[active=&quot;true&quot;] {
    background-color: #efe0cc;
    color: #2d3748;
    font-weight: bold;
    border-left: 3px solid #4a90d9;
}

/* ---------- 内容区 ---------- */
#mainContentFrame {
    background-color: #FFFAF0;
    border: none;
}

/* 页面标题 */
#currentPageLbl {
    color: #2d3748;
    font-size: 22px;
    font-weight: bold;
    padding: 4px 0px;
    qproperty-alignment: 'AlignLeft | AlignVCenter';
}

/* ---------- 表格 ---------- */
QTableView {
    background-color: #FEF9F0;
    alternate-background-color: #FBF3E4;
    border: 1px solid #e0d8c8;
    border-radius: 12px;
    gridline-color: transparent;
    selection-background-color: #f0e5d0;
    selection-color: #2d3748;
    font-size: 13px;
}

QTableView::item {
    padding: 10px 16px;
    border-bottom: 1px solid #f0e8d8;
}

QHeaderView::section {
    background-color: #F5ECD7;
    color: #5a4a3a;
    font-weight: bold;
    font-size: 12px;
    padding: 12px 16px;
    border: none;
    border-bottom: 2px solid #d8cfb8;
}

/* ---------- 内容区按钮 ---------- */
#addCourseBtn, #addExpBtn, #addAwardBtn {
    background-color: #4a90d9;
    color: #ffffff;
    border: none;
    border-radius: 8px;
    padding: 9px 22px;
    font-size: 13px;
    font-weight: bold;
}

#addCourseBtn:hover, #addExpBtn:hover, #addAwardBtn:hover {
    background-color: #357abd;
}

#addCourseBtn:pressed, #addExpBtn:pressed, #addAwardBtn:pressed {
    background-color: #2a6cb5;
}

#deleteCourseBtn, #DelExpBtn, #delAwardBtn {
    background-color: #ffffff;
    color: #e53e3e;
    border: 1px solid #e53e3e;
    border-radius: 8px;
    padding: 9px 22px;
    font-size: 13px;
    font-weight: bold;
}

#deleteCourseBtn:hover, #DelExpBtn:hover, #delAwardBtn:hover {
    background-color: #fff5f5;
}

#deleteCourseBtn:pressed, #DelExpBtn:pressed, #delAwardBtn:pressed {
    background-color: #fed7d7;
}

/* ---------- 输入控件 ---------- */
QLineEdit, QComboBox, QDateEdit, QDoubleSpinBox, QSpinBox {
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    padding: 8px 12px;
    background-color: #ffffff;
    color: #2d3748;
    font-size: 13px;
    min-height: 20px;
}

QLineEdit:focus, QComboBox:focus, QDateEdit:focus,
QDoubleSpinBox:focus, QSpinBox:focus {
    border-color: #4a90d9;
}

QComboBox::drop-down {
    border: none;
    padding-right: 8px;
}

QComboBox QAbstractItemView {
    background-color: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 6px;
    selection-background-color: #e8f0fe;
    selection-color: #2d3748;
    padding: 4px;
}

/* ---------- 日历弹窗 ---------- */
QCalendarWidget QWidget {
    background-color: #ffffff;
}

QCalendarWidget QAbstractItemView:enabled {
    selection-background-color: #4a90d9;
    selection-color: #ffffff;
}

QDateEdit::drop-down {
    border: none;
    padding-right: 6px;
}

/* ---------- 表单框架 (课程/经历/荣誉的添加区域) ---------- */
#addCourseFrame, #addExpFrame, #addAwardFrame {
    background-color: #FDF5E6;
    border: 1px solid #e0d8c8;
    border-radius: 12px;
}

/* ---------- 表单标签 ---------- */
#addCourseNameLbl, #addCourseCreditLbl, #addCourseScoreLbl, #addCourseSemesterLbl,
#addExpTypeLbl, #addExpTitleLbl, #addExpDateLbl, #addExpDescLbl,
#addAwardTitleLbl, #addAwardDateLbl, #addAwardLevelLbl {
    color: #5a4a3a;
    font-size: 13px;
    font-weight: bold;
}

/* ---------- 统计标签 ---------- */
#labelStats {
    color: #5a4a3a;
    font-size: 14px;
    font-weight: bold;
    background-color: #F5ECD7;
    border: 1px solid #e0d8c8;
    border-radius: 10px;
    padding: 12px;
    qproperty-alignment: 'AlignCenter';
}

/* ---------- 滚动条 ---------- */
QScrollBar:vertical {
    background-color: transparent;
    width: 8px;
    margin: 0px;
}

QScrollBar::handle:vertical {
    background-color: #c4c4d4;
    border-radius: 4px;
    min-height: 30px;
}

QScrollBar::handle:vertical:hover {
    background-color: #a0aec0;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0px;
}

QScrollBar:horizontal {
    background-color: transparent;
    height: 8px;
}

QScrollBar::handle:horizontal {
    background-color: #c4c4d4;
    border-radius: 4px;
    min-width: 30px;
}

QScrollBar::handle:horizontal:hover {
    background-color: #a0aec0;
}

QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
    width: 0px;
}

/* ---------- 首页 Dashboard 卡片 ---------- */
#dashCard {
    background-color: #F0E5D0;
    border: 1px solid #e0d5bb;
    border-radius: 14px;
}

#dashCard:hover {
    background-color: #EBDCC2;
    border: 1px solid #d4c9a8;
}

/* ---------- 提示框 ---------- */
QMessageBox {
    background-color: #ffffff;
}

QMessageBox QPushButton {
    background-color: #4a90d9;
    color: #ffffff;
    border: none;
    border-radius: 6px;
    padding: 8px 20px;
    font-size: 13px;
    min-width: 80px;
}

QMessageBox QPushButton:hover {
    background-color: #357abd;
}</string>
